# Copy this file to `.env` and fill in the values, then restart `npm run dev`.
# (The real `.env` is gitignored so secrets never get committed.)

# Required for the AI nutrition lookup routes (text + photo).
# Get a free key at https://aistudio.google.com/apikey  — no quotes.
# The core tracker works without this; only /api/nutrition/* needs it.
GEMINI_API_KEY=

# Optional — usually fine to leave as the defaults.
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — path to the local JSON database (defaults to ./data/foodlog.json).
# DATA_FILE=./data/foodlog.json
